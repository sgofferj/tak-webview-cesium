# TAK Server Connection
TAK_HOST=localhost
TAK_PORT=8089

# mTLS Certificates (Paths relative to the backend directory or absolute)
# If using Docker, these should match the mount points in docker-compose.yml
TAK_TLS_CLIENT_CERT=certs/cert.pem
TAK_TLS_CLIENT_KEY=certs/cert.key
TAK_TLS_CA_CERT=certs/ca.pem

# Identity Configuration
TAK_CALLSIGN=CesiumViewer
TAK_TYPE=a-f-G-U-C-I
TAK_UID=CesiumViewer-Default

# Debugging
LOG_COTS=false

# Backend Server Port
PORT=8000
