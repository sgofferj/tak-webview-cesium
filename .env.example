# TAK Server Connection
TAK_HOST=localhost
TAK_PORT=8089

# Identity Configuration
TAK_CALLSIGN=CesiumViewer
TAK_TYPE=a-f-G-U-C-I
# TAK_UID=CesiumViewer-MyUniqueName

# Security
# If not set, a random secret will be generated on every startup (recommended for security)
# Setting this will persist sessions across container restarts.
# SECRET_KEY=your-long-random-secret-key-here

# Feature Configuration
LOG_COTS=false
CENTER_ALERT=true
TERRAIN_URL=https://tiles.gofferje.net/cesium
TERRAIN_EXAGGERATION=1.0

# Map Settings
INITIAL_LAT=60.1699
INITIAL_LON=24.9384

# Production/Network Configuration
PORT=8000
TRUSTED_PROXIES=127.0.0.1,172.17.0.1

# Path Configuration (Internal container paths)
USER_ICONSETS_DIR=/user_iconsets
LAYERS_CONFIG_FILE=customlayers.json
