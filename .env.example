# TAK Server Connection
TAK_HOST=localhost
TAK_PORT=8089
TAK_TLS_CLIENT_CERT=certs/cert.pem
TAK_TLS_CLIENT_KEY=certs/cert.key
# TAK_TLS_CA_CERT=certs/ca.pem

# Viewer Identity
TAK_CALLSIGN=CesiumViewer
# TAK_TYPE=a-f-G-U-C-I
# TAK_UID=CesiumViewer-MyUniqueName

# Feature Configuration
LOG_COTS=false
CENTER_ALERT=false
ICONSETS_DIR=/iconsets
USER_ICONSETS_DIR=/user_iconsets
TERRAIN_URL=

# Production/Network Configuration
PORT=8000
TRUSTED_PROXIES=127.0.0.1,172.17.0.1

# Frontend Configuration (Build-time)
VITE_CESIUM_ION_TOKEN=your_token_here
# VITE_WS_HOST=your_host_here
